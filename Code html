<!DOCTYPE html>
<html lang="fr">
<head>
 <meta charset="UTF-8">
 <meta name="viewport" content="width=device-width, initial-scale=1.0">
 <title>Omeza Coffee Gallery • Menu</title>
 <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>☕</text></svg>">
 <link rel="preconnect" href="https://fonts.googleapis.com">
 <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
 <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">

 <style>
     * {
         margin: 0;
         padding: 0;
         box-sizing: border-box;
     }

     html {
         scroll-behavior: smooth;
     }

     body {
         background: radial-gradient(ellipse at center, #1a0f08 0%, #0a0503 100%);
         color: #e8d5c4;
         font-family: 'Lato', sans-serif;
         font-weight: 300;
         line-height: 1.6;
         min-height: 100vh;
         position: relative;
     }

     /* Subtle gold grain overlay */
     body::before {
         content: "";
         position: fixed;
         top: 0;
         left: 0;
         width: 100%;
         height: 100%;
         background-image: url("data:image/svg+xml,%3Csvg width='100' height='100' viewBox='0 0 100 100' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100' height='100' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
         pointer-events: none;
         z-index: 0;
     }

     /* Glass card wrapper */
     .glass-container {
         position: relative;
         z-index: 1;
         background: rgba(20, 15, 10, 0.55);
         backdrop-filter: blur(18px);
         -webkit-backdrop-filter: blur(18px);
         border: 1px solid rgba(200, 155, 60, 0.25);
         border-radius: 32px;
         max-width: 900px;
         margin: 30px auto;
         box-shadow: 0 30px 50px rgba(0,0,0,0.7),
                     0 0 100px rgba(200, 155, 60, 0.1);
         overflow: hidden;
     }

     header {
         text-align: center;
         padding: 40px 20px 30px;
         background: rgba(10, 5, 3, 0.5);
         backdrop-filter: blur(10px);
         -webkit-backdrop-filter: blur(10px);
         border-bottom: 1px solid rgba(200, 155, 60, 0.4);
         position: relative;
     }

     header h1 {
         font-family: 'Playfair Display', serif;
         color: #c89b3c;
         font-size: 3.2rem;
         letter-spacing: 5px;
         text-transform: uppercase;
         text-shadow: 0 0 30px rgba(200, 155, 60, 0.5);
         margin: 0;
         line-height: 1.2;
     }

     header .subtitle {
         color: #b89a7a;
         font-style: italic;
         letter-spacing: 2px;
         margin-top: 12px;
         font-size: 1rem;
         font-weight: 300;
     }

     /* Navigation with glass */
     nav {
         position: sticky;
         top: 0;
         background: rgba(10, 5, 3, 0.7);
         backdrop-filter: blur(20px);
         -webkit-backdrop-filter: blur(20px);
         display: flex;
         flex-wrap: wrap;
         justify-content: center;
         gap: 12px;
         padding: 15px 20px;
         z-index: 1000;
         border-bottom: 1px solid rgba(200, 155, 60, 0.3);
         box-shadow: 0 10px 25px rgba(0,0,0,0.5);
     }

     nav a {
         color: #d4c1ae;
         text-decoration: none;
         padding: 8px 18px;
         border: 1px solid rgba(200, 155, 60, 0.4);
         border-radius: 30px;
         font-size: 0.9rem;
         letter-spacing: 1px;
         font-weight: 400;
         transition: all 0.3s ease;
         background: rgba(200, 155, 60, 0.05);
         backdrop-filter: blur(5px);
         -webkit-backdrop-filter: blur(5px);
     }

     nav a:hover,
     nav a.active {
         background: rgba(200, 155, 60, 0.25);
         color: #fff;
         border-color: #c89b3c;
         box-shadow: 0 0 20px rgba(200, 155, 60, 0.4);
         transform: translateY(-2px);
     }

     main {
         padding: 30px 35px 40px;
     }

     section {
         padding: 40px 0;
         border-bottom: 1px solid rgba(200, 155, 60, 0.15);
     }

     section:last-of-type {
         border-bottom: none;
     }

     h2 {
         font-family: 'Playfair Display', serif;
         color: #c89b3c;
         font-size: 2rem;
         margin-bottom: 15px;
         border-left: 4px solid #c89b3c;
         padding-left: 18px;
         text-shadow: 0 0 10px rgba(200, 155, 60, 0.3);
         letter-spacing: 1px;
     }

     .section-note {
         margin: -5px 0 20px 20px;
         font-style: italic;
         color: #b8a086;
         font-size: 0.9rem;
         border-left: 2px solid rgba(200, 155, 60, 0.4);
         padding-left: 15px;
     }

     .item {
         display: flex;
         justify-content: space-between;
         align-items: center;
         padding: 12px 18px;
         margin: 6px 0;
         border-radius: 16px;
         background: rgba(255, 255, 255, 0.02);
         backdrop-filter: blur(8px);
         -webkit-backdrop-filter: blur(8px);
         border: 1px solid rgba(200, 155, 60, 0.12);
         transition: all 0.3s ease;
     }

     .item:hover {
         background: rgba(200, 155, 60, 0.08);
         border-color: rgba(200, 155, 60, 0.4);
         box-shadow: 0 5px 20px rgba(0,0,0,0.3);
         transform: translateY(-1px);
     }

     .item-name {
         display: flex;
         flex-wrap: wrap;
         align-items: baseline;
         gap: 8px;
     }

     .note {
         font-size: 0.8rem;
         color: #a3907b;
         font-style: italic;
         opacity: 0.9;
     }

     .sub-group {
         margin: 20px 0 5px 15px;
         padding: 10px 15px;
         border-left: 2px solid rgba(200, 155, 60, 0.5);
         background: rgba(200, 155, 60, 0.03);
         border-radius: 0 12px 12px 0;
     }

     .sub-group p.sub-heading {
         font-family: 'Playfair Display', serif;
         color: #d4af37;
         margin: 0 0 10px 0;
         font-size: 1.1rem;
         font-weight: 700;
         letter-spacing: 1px;
     }

     .sub-group .item {
         background: none;
         backdrop-filter: none;
         border: none;
         padding: 8px 0;
         margin: 2px 0;
     }

     footer {
         text-align: center;
         padding: 25px;
         background: rgba(10, 5, 3, 0.5);
         backdrop-filter: blur(10px);
         -webkit-backdrop-filter: blur(10px);
         border-top: 1px solid rgba(200, 155, 60, 0.4);
         color: #b8a086;
         font-size: 0.9rem;
         letter-spacing: 0.5px;
     }

     footer p {
         margin: 6px 0;
     }

     @media (max-width: 700px) {
         .glass-container {
             margin: 10px;
             border-radius: 20px;
         }

         header h1 {
             font-size: 2.2rem;
             letter-spacing: 3px;
         }

         nav a {
             padding: 6px 14px;
             font-size: 0.8rem;
         }

         .item {
             flex-direction: column;
             align-items: flex-start;
             gap: 5px;
         }
     }
 </style>
</head>
<body>
 <div class="glass-container">
     <header>
         <h1>Omeza Coffee Gallery</h1>
         <p class="subtitle">L'art du café depuis 1927</p>
     </header>

     <nav id="navbar">
         <a href="#espresso">Espresso</a>
         <a href="#specialty">Specialty</a>
         <a href="#coffee-gallery">Gallery</a>
         <a href="#choco">Choco</a>
         <a href="#cold">Cold</a>
         <a href="#boissons">Boissons</a>
         <a href="#beans">Grains</a>
     </nav>

     <main>
         <!-- ESPRESSO -->
         <section id="espresso">
             <h2>Espresso</h2>
             <div class="item"><span class="item-name">Espresso</span></div>
             <div class="item"><span class="item-name">Ristretto</span></div>
             <div class="item"><span class="item-name">Americano</span></div>
             <div class="item"><span class="item-name">Double Espresso</span></div>
         </section>

         <!-- SPECIALTY -->
         <section id="specialty">
             <h2>Speciality Coffee</h2>
             <p class="section-note">
                 Selon la disponibilité et selon l'arrivage. (Éthiopie, Colombie, Brésil, Honduras, Elixir d’Arabica)
             </p>
             <div class="item"><span class="item-name">Chemex</span></div>
             <div class="item"><span class="item-name">V60</span></div>
             <div class="item"><span class="item-name">Kalita</span></div>
             <div class="item"><span class="item-name">French Press</span></div>
             <div class="item"><span class="item-name">Syphon</span></div>
             <div class="item"><span class="item-name">Aeropress</span></div>
             <div class="item"><span class="item-name">Turkish</span></div>
         </section>

         <!-- COFFEE GALLERY -->
         <section id="coffee-gallery">
             <h2>Coffee Gallery</h2>
             <div class="item"><span class="item-name">Café Aromatisé</span></div>
             <div class="item"><span class="item-name">Cappuccino Omeza</span></div>
             <div class="item"><span class="item-name">Bonbon <span class="note">(Au lait concentré)</span></span></div>
             <div class="item"><span class="item-name">Cappuccino Aromatisé</span></div>
             <div class="item"><span class="item-name">Babyccino</span></div>
             <div class="item"><span class="item-name">Cappuccino Chantilly</span></div>
             <div class="item"><span class="item-name">Macchiato</span></div>
             <div class="item"><span class="item-name">Mokaccino</span></div>
             <div class="item"><span class="item-name">Latte Macchiato</span></div>
             <div class="item"><span class="item-name">Diablo</span></div>
             <div class="item"><span class="item-name">Cortado</span></div>
             <div class="item"><span class="item-name">Affogato</span></div>
             <div class="item"><span class="item-name">Con Panna</span></div>
         </section>

         <!-- CHOCO -->
         <section id="choco">
             <h2>Choco Gallery</h2>
             <div class="item"><span class="item-name">Chocolat Chaud</span></div>
             <div class="item"><span class="item-name">Chocolat Fondu + Banane</span></div>
             <div class="item"><span class="item-name">Bianco Nero</span></div>
             <div class="item"><span class="item-name">Choco Caramello</span></div>
             <div class="item"><span class="item-name">Chocolat Latte</span></div>
             <div class="item"><span class="item-name">Choco Monte Cristo</span></div>
         </section>

         <!-- COLD COFFEE -->
         <section id="cold">
             <h2>Cold Coffee</h2>
             <div class="item"><span class="item-name">Ice Espresso</span></div>
             <div class="item"><span class="item-name">Ice Latte Coffee</span></div>
             <div class="item"><span class="item-name">Spanish Ice Coffee</span></div>
             <div class="item"><span class="item-name">Ice Caramel Macchiato</span></div>
             <div class="item"><span class="item-name">Vanilla Ice Coffee</span></div>
             <div class="item"><span class="item-name">Coffee Lassi</span></div>
             <div class="item"><span class="item-name">Coffee Cola</span></div>

             <div class="sub-group">
                 <p class="sub-heading">Frappuccino</p>
                 <div class="item"><span class="item-name">Frappuccino Oreo</span></div>
                 <div class="item"><span class="item-name">Frappuccino Cookies</span></div>
                 <div class="item"><span class="item-name">Frappuccino Kinder</span></div>
                 <div class="item"><span class="item-name">Frappuccino Nutella</span></div>
                 <div class="item"><span class="item-name">Frappuccino Lotus</span></div>
                 <div class="item"><span class="item-name">Frappuccino Caramel</span></div>
             </div>
         </section>

         <!-- BOISSONS FRAÎCHES -->
         <section id="boissons">
             <h2>Boissons Fraîches</h2>
             <div class="item"><span class="item-name">Eau Minérale / Gazeuse <span class="note">50cl</span></span></div>
             <div class="item"><span class="item-name">Soda</span></div>
         </section>

         <!-- BEANS -->
         <section id="beans">
             <h2>Café en Grains</h2>
             <div class="item"><span class="item-name">Robusta <span class="note">125g, 250g, 500g, 1kg</span></span></div>
             <div class="item"><span class="item-name">Spécial Omeza <span class="note">125g, 250g, 500g, 1kg</span></span></div>
             <div class="item"><span class="item-name">Arabica <span class="note">125g, 250g, 500g, 1kg</span></span></div>
             <div class="item"><span class="item-name">Elixir D'arabica <span class="note">125g, 250g, 500g, 1kg</span></span></div>
             <div class="item"><span class="item-name">Café Vert <span class="note">125g, 250g, 500g, 1kg</span></span></div>
         </section>
     </main>

     <footer>
         <p><strong>Omeza Coffee Gallery</strong> — L’authenticité du grain à la tasse</p>
         <p>Ouvert du lundi au samedi • 7h – 19h</p>
         <p>© 2025 Omeza Coffee Gallery</p>
     </footer>
 </div>

 <script>
     // Scroll spy – add/remove 'active' class based on visible section
     const sections = document.querySelectorAll('section');
     const navLinks = document.querySelectorAll('nav a');

     const observerOptions = {
         root: null,
         rootMargin: '0px 0px -60% 0px',
         threshold: 0
     };

     const observer = new IntersectionObserver((entries) => {
         entries.forEach(entry => {
             if (entry.isIntersecting) {
                 const id = entry.target.getAttribute('id');
                 navLinks.forEach(link => {
                     link.classList.remove('active');
                     if (link.getAttribute('href') === '#' + id) {
                         link.classList.add('active');
                     }
                 });
             }
         });
     }, observerOptions);

     sections.forEach(section => observer.observe(section));
 </script>
</body>
</html>
